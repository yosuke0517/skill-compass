DATABASE_URL=mysql://skill_compass:skill_compass@127.0.0.1:3306/skill_compass
SESSION_SECRET=replace-with-at-least-32-random-characters
MARKDOWN_EXPORT_DIR=./exports/skill-compass
LLM_PROVIDER=deterministic
ASSISTANT_PROVIDER=deterministic
NOTE_WRITER=filesystem

TRANSLATION_PROVIDER=deterministic
QUIZ_GENERATION_PROVIDER=deterministic
CLAUDE_CLI_COMMAND=claude
CLAUDE_CLI_TIMEOUT_MS=10000
GEMINI_API_KEY=
GEMINI_API_KEY_SOURCE=env
GEMINI_KEYCHAIN_SERVICE=
GEMINI_KEYCHAIN_ACCOUNT=
GEMINI_TRANSLATION_MODEL=gemini-2.5-flash-lite
GEMINI_QUIZ_MODEL=gemini-2.5-flash-lite
GEMINI_SCRIPT_MODEL=gemini-2.5-flash-lite
GEMINI_ASSISTANT_MODEL=gemini-2.5-flash-lite
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=https://example.com/api/integrations/google/callback
GOOGLE_OAUTH_CLIENT_SECRET_KEYCHAIN_SERVICE=skill-compass/google-oauth-client-secret
X_OAUTH_CLIENT_ID=
X_OAUTH_REDIRECT_URI=https://example.com/api/integrations/x/callback
X_OAUTH_CLIENT_SECRET_KEYCHAIN_SERVICE=skill-compass/x-oauth-client-secret
PODCAST_AUDIO_STORAGE=filesystem
PODCAST_AUDIO_STORAGE_DIR=./var/skill-compass-audio
PODCAST_R2_ACCOUNT_ID=
PODCAST_R2_BUCKET_NAME=
PODCAST_R2_ACCESS_KEY_ID=
PODCAST_R2_SECRET_ACCESS_KEY=
PODCAST_R2_CREDENTIALS_SOURCE=env
PODCAST_R2_ACCESS_KEY_KEYCHAIN_SERVICE=skill-compass/podcast-r2-access-key
PODCAST_R2_SECRET_KEY_KEYCHAIN_SERVICE=skill-compass/podcast-r2-secret-key
PODCAST_R2_KEYCHAIN_ACCOUNT=
NEXT_ALLOWED_DEV_ORIGINS=
